# TradingView MCP Local Setup
# Copy this to .env and fill in your values

# Anthropic API Key - get from https://console.anthropic.com/
# This allows Claude to generate Pine Scripts
ANTHROPIC_API_KEY=sk-ant-v1-xxx...

# ngrok Auth Token - get FREE from https://ngrok.com/
# This creates a public URL for your local MCP server
NGROK_AUTHTOKEN=xxx_zzz...

# After starting docker-compose:
# 1. ngrok will output a public URL like: https://xxxx-xx-xxx-x.ngrok.io
# 2. Share this URL with your backend provider
# 3. Set TRADINGVIEW_MCP_URL=https://xxxx-xx-xxx-x.ngrok.io in Railway backend
# 4. Restart Railway backend
