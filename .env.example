# Bitiq Lab Environment Configuration

# ============================================
# Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# Anthropic (Claude API)
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================
# Binance API (Testnet for Paper Trading)
# ============================================
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret
BINANCE_API_KEY=your_mainnet_api_key  # For future live trading
BINANCE_API_SECRET=your_mainnet_api_secret

# ============================================
# TradingView MCP Configuration
# ============================================
TRADINGVIEW_MCP_URL=http://localhost:3000
TRADINGVIEW_MCP_API_KEY=your_mcp_api_key

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Features & Flags
# ============================================
ENABLE_AUTO_RESEARCH=true
ENABLE_PAPER_TRADING=true
ENABLE_LIVE_TRADING=false

# ============================================
# Backtest Engine Configuration
# ============================================
BACKTEST_ENGINE_WORKERS=4  # Number of parallel backtest workers
BACKTEST_ENGINE_TIMEOUT=600000  # 10 minutes

# ============================================
# Paper Trading Configuration
# ============================================
PAPER_TRADING_INITIAL_CAPITAL=10000
PAPER_TRADING_USE_TESTNET=true
PAPER_TRADING_MIN_DAYS=14
PAPER_TRADING_MIN_TRADES=30

# ============================================
# LLM Configuration
# ============================================
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info
ENABLE_SENTRY=false
SENTRY_DSN=

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/bitiqlab

# ============================================
# Redis (optional, for caching)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Development Settings
# ============================================
NEXT_PUBLIC_DEBUG=false
VERBOSE_LOGGING=false
