# Database Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Binance Testnet Configuration
# Get API keys from: https://testnet.binance.vision/
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# Binance Production Configuration (for live trading - USE CAUTION!)
# Only uncomment and set these if you're deploying to production
# BINANCE_LIVE_API_KEY=your_live_api_key_here
# BINANCE_LIVE_API_SECRET=your_live_api_secret_here

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
API_PORT=3000

# Claude AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Environment
NODE_ENV=development
